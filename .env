# =============================================================================
# NeuroStage Pipeline — Environment Configuration
# 
# HOW TO USE:
#   cp .env.template .env
#   Open .env and fill in the three fields marked REQUIRED below.
#   Everything else is pre-configured and does not need to change.
# =============================================================================

# ── REQUIRED: Fill these in ───────────────────────────────────────────────────

# Absolute path to the neurostage_pipeline folder on your machine
PIPELINE_BASE=/mnt/data_raid/Gaurav/neurostage_pipeline

OUTPUT_BASE=/mnt/data_raid/Gaurav/neurostage_pipeline

# Raw DICOM input for this subject (folder, nested folder, or .zip file)
DICOM_INPUT=/mnt/data_raid/P2D2/P2D2_UAB/DICOM/P2D2_1090_00_Mishra

# Subject label (no "sub-" prefix)
SUBJECT_ID=1090

# ── ASL Configuration ─────────────────────────────────────────────────────────
# Labeling type for your ASL acquisition. Must be PCASL, CASL, or PASL.
# If left empty, you will be prompted interactively when ASLPrep runs.
ASL_LABELING_TYPE=PCASL

# Where is you matlab store
MATLAB_COMPILER_RUNTIME=/usr/local/MATLAB/R2025b/

# ── OPTIONAL: Session label ───────────────────────────────────────────────────
SESSION_ID=                              # Leave empty if your data has no sessions

# ── Pre-configured: derived from PIPELINE_BASE ────────────────────────────────
# These point to tools that are already bundled inside the pipeline folder.
# Do not change these unless you have moved something.

FS_LICENSE=$PIPELINE_BASE/license.txt
DCM2BIDS_CONFIG=$PIPELINE_BASE/dcm2bids_config.json
FREESURFER_HOME=$PIPELINE_BASE/freesurfer
FSLDIR=$PIPELINE_BASE/fsl
HCPPIPEDIR=$PIPELINE_BASE/HCPpipelines
MSMBINDIR=$HCPPIPEDIR/pipeline_tools
CARET7DIR=$PIPELINE_BASE/workbench/bin_linux64
LD_LIBRARY_PATH=$HCPPIPEDIR/OpenBLAS/
BLAS=$HCPPIPEDIR/OpenBLAS/libopenblas.a
ATLAS=$HCPPIPEDIR/OpenBLAS/libopenblas.a

# ── Docker Images ─────────────────────────────────────────────────────────────
# Pinned versions for reproducibility. Do not change unless intentionally upgrading.
MRIQC_IMAGE=nipreps/mriqc:latest
QSIPREP_IMAGE=pennlinc/qsiprep:latest
FMRIPREP_IMAGE=nipreps/fmriprep:latest
ASLPREP_IMAGE=pennlinc/aslprep:latest
 
# FreeSurfer's recon-all output format is tightly coupled to what the HCP
# step (04_hcp_preproc.sh) and downstream surface-map processing expect.
# Bumping this version can silently change surface outputs in ways that
# break compatibility with the rest of the pipeline. Only change this if
# you have explicitly verified compatibility end-to-end.
FREESURFER_IMAGE=freesurfer/freesurfer:7.4.1

# ── Pipeline Steps ────────────────────────────────────────────────────────────
# Set to 0 to skip a step, 1 to run it.
RUN_DCM2BIDS=1
RUN_MRIQC=1
RUN_FREESURFER=1
RUN_HCP=1
RUN_QSIPREP=1
RUN_FMRIPREP=1
RUN_ASLPREP=1

# ── Resource Limits ───────────────────────────────────────────────────────────
N_THREADS=40             # CPU threads given to each tool
MEM_GB=256               # RAM limit (GB) passed to fMRIPrep / QSIPrep / ASLPrep
OUTPUT_RESOLUTION=1     # QSIPrep output resolution in mm

# ── GPU (QSIPrep eddy) ────────────────────────────────────────────────────────
# AUTO = detect GPU at runtime; use eddy_cuda if available, else fall back to CPU
# ON   = force GPU (will fail if no NVIDIA GPU is present)
# OFF  = always use CPU eddy
EDDY_GPU=AUTO

# ── Parallel Execution ────────────────────────────────────────────────────────
# Set to 1 to run steps within each stage simultaneously.
# WARNING: Parallel mode is RAM-intensive:
#   PARALLEL_STAGE1=1  →  needs ~60 GB RAM  (MRIQC + FreeSurfer + HCP together)
#   PARALLEL_STAGE2=1  →  needs ~100 GB RAM (QSIPrep + fMRIPrep + ASLPrep together)
# Leave as 0 on machines with limited RAM.
PARALLEL_STAGE1=1
PARALLEL_STAGE2=1
